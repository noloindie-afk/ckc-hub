function fixRksStatus() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName('Catalog');
  const data = sheet.getDataRange().getValues();

  const headers = data[0];
  const statusCol = headers.indexOf('Status');

  if (statusCol === -1) {
    throw new Error('Status column not found');
  }

  let fixed = 0;

  for (let i = 1; i < data.length; i++) {
    if (data[i][statusCol] === 'rks') {
      sheet.getRange(i + 1, statusCol + 1).setValue('active');
      fixed++;
    }
  }

  SpreadsheetApp.getUi().alert(`Done — updated ${fixed} rows from "rks" → "active".`);
}
